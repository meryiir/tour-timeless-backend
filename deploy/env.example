# Copy to .env next to docker-compose.prod.yml and edit before `docker compose up`.
# Never commit .env.

DB_PASSWORD=change-me-strong-db-password
JWT_SECRET=change-me-minimum-32-characters-random-secret
# Canonical public URL (sitemap, SEO, OAuth). No trailing slash.
SITE_PUBLIC_URL=https://morocco-mosaic.com
# Include both apex and www if you serve either (comma-separated, no spaces).
CORS_ORIGINS=https://morocco-mosaic.com,https://www.morocco-mosaic.com

# OAuth (optional; must match Google Cloud Web client)
GOOGLE_CLIENT_ID=

# Host port for nginx (SPA + /api proxy). Use 8080 if something else uses 80.
HTTP_PORT=80

# Frontend repo path relative to backend/deploy/ (compose file directory).
# VPS with sibling clones: tour-timeless next to tour-timeless-backend → default is fine.
# FRONTEND_CONTEXT=../../tour-timeless
#
# Local monorepo (…/tourisme/backend + …/tourisme/frontend/tour-timeless):
# FRONTEND_CONTEXT=../../frontend/tour-timeless
