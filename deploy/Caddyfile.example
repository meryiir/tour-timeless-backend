# Optional: terminate TLS in front of the compose stack (frontend container on port 80).
# Copy to e.g. /etc/caddy/Caddyfile and adjust upstream if needed.
#
# Example when frontend maps to host port 80:
#   docker compose ...  # HTTP_PORT=80
#   caddy run --config /etc/caddy/Caddyfile
#
# Example upstream when compose project is "deploy" (container name tourisme-frontend):
#   reverse_proxy tourisme-frontend:80

morocco-mosaic.com, www.morocco-mosaic.com {
    reverse_proxy localhost:80
}
